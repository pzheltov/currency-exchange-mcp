# Optional: Override the server port (default: 3000)
# Apify sets this automatically in production via APIFY_CONTAINER_PORT
APIFY_CONTAINER_PORT=3000

# Optional (stdio mode only): redirect logs to this file instead of stderr.
# Useful when running under Claude Desktop, which captures stderr but doesn't
# always surface it. Absolute path recommended.
# MCP_LOG_FILE=/tmp/currency-exchange-mcp.log
