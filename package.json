{
	"name": "currency-exchange-mcp",
	"version": "1.0.0",
	"type": "module",
	"description": "MCP server for real-time currency exchange rates and crypto prices. Convert between 60+ fiat currencies and 30+ cryptocurrencies with multi-source fallback.",
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.17.5",
		"apify": "^3.4.4",
		"cors": "^2.8.5",
		"express": "^5.1.0",
		"got-scraping": "^4.0.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@apify/eslint-config": "^1.0.0",
		"@apify/tsconfig": "^0.1.1",
		"@types/cors": "^2.8.13",
		"@types/express": "^5.0.2",
		"@types/node": "^22.15.32",
		"eslint": "^9.29.0",
		"eslint-config-prettier": "^10.1.5",
		"globals": "^17.0.0",
		"prettier": "^3.5.3",
		"tsx": "^4.20.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.34.1",
		"vitest": "^3.0.0",
		"@vitest/coverage-v8": "^3.0.0"
	},
	"scripts": {
		"start": "npm run start:dev",
		"start:prod": "node dist/main.js",
		"start:dev": "tsx src/main.ts",
		"build": "tsc",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"keywords": [
		"mcp",
		"mcp-server",
		"currency",
		"exchange-rate",
		"forex",
		"crypto",
		"bitcoin",
		"currency-converter",
		"fx-rates",
		"financial-data",
		"real-time-rates",
		"cryptocurrency",
		"conversion",
		"multi-currency",
		"apify"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Ruddxxy/currency-exchange-mcp"
	},
	"bugs": {
		"url": "https://github.com/Ruddxxy/currency-exchange-mcp/issues"
	},
	"homepage": "https://github.com/Ruddxxy/currency-exchange-mcp#readme",
